# Endereço do host do banco de dados (local ou remoto, como Railway)
DB_HOST=localhost
# Nome de usuário do banco
DB_USER=root
# Senha do banco de dados
DB_PASSWORD=sua_senha_aqui
# Nome do banco de dados que será usado
DB_NAME=sistema_ordem_servico
# Porta do banco de dados
DB_PORT=3006
# Porta em que o servidor backend irá rodar
PORT=3000